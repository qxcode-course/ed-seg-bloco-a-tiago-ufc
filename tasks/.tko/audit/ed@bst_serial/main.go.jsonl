{"ts":1783909195,"hash":"95496d6310eb9b1bc07603fa7b78a00212ab004d808b074df5cc640633267768","mode":"diff","ops":[{"tag":"insert","a1":41,"a2":41,"text":"\tdfs = func(n *Node) {\n\t\tif n == nil {\n\t\t\tout = append(out, \"#\")\n\t\t\treturn\n\t\t}\n\t\tout = append(out, fmt.Sprintf(\"%d\", n.Value))\n\t\tdfs(n.Left)\n\t\tdfs(n.Right)\n\t}\n"}]}
