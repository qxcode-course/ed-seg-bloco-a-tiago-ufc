{"ts":1783909055,"hash":"94739d9e293380cb7f51404404e0fd9d232e62089d56332ab5868d7f6fde3ddf","mode":"diff","ops":[{"tag":"insert","a1":20,"a2":20,"text":"}\n\nfunc BstInsert(values []int) *Node {\n\tvar root *Node\n\tfor _, v := range values {\n\t\troot = insert(root, v)\n\t}\n\treturn root\n"}]}
{"ts":1783909084,"hash":"80bcbd6e3089e5051dfd21cfd8927dca72bea72c8ba9130b5ebd7d339b1c60c4","mode":"diff","ops":[{"tag":"replace","a1":16,"a2":20,"text":"func insert(root *Node, value int) *Node {\n\tif root == nil {\n\t\treturn &Node{Value: value}\n\t}\n\tif value < root.Value {\n\t\troot.Left = insert(root.Left, value)\n\t} else if value > root.Value {\n\t\troot.Right = insert(root.Right, value)\n\t}\n\treturn root\n"}]}
