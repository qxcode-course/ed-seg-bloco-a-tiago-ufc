{"ts":1783871388,"hash":"230710ce86eecb573c57a53c39bbd43517b54373546ab6b806367d42a6c7e3b3","mode":"diff","ops":[{"tag":"insert","a1":8,"a2":8,"text":"type Pos struct {\n\tl, c int\n}\n\nfunc get_size(grid [][]rune) (int, int) {\n\treturn len(grid), len(grid[0])\n}\n\nfunc is_value(grid [][]rune, pos Pos, value rune) bool {\n\tnl, nc := get_size(grid)\n\tl := pos.l\n\tc := pos.c\n\tif c < 0 || c >= nc || l < 0 || l >= nl {\n\t\treturn false\n\t}\n\treturn grid[l][c] == value\n}\n\nfunc getNeig(p Pos) []Pos {\n\treturn []Pos{{p.l, p.c - 1}, {p.l - 1, p.c}, {p.l, p.c + 1}, {p.l + 1, p.c}}\n}\n\nfunc is_inside(grid [][]rune, pos Pos) bool {\n\tnl, nc := get_size(grid)\n\treturn pos.l >= 0 && pos.l < nl && pos.c >= 0 && pos.c < nc\n}\n\n"},{"tag":"replace","a1":10,"a2":20,"text":"\tvisited := make(map[Pos]bool)\n\tstart := Pos{l, c}\n\tstack.Push(start)\n\tfor !stack.IsEmpty() {\n\t\telem := stack.Pop()\n\t\tif !is_inside(grid, elem) {\n\t\t\tcontinue\n\t\t}\n\t\tif grid[elem.l][elem.c] != '#' {\n\t\t\tcontinue\n\t\t}\n\t\tif visited[elem] {\n\t\t\tcontinue\n\t\t}\n\t\tvisited[elem] = true\n\t\tgrid[elem.l][elem.c] = 'o'\n\t\tfor _, neig := range getNeig(elem) {\n\t\t\tif is_inside(grid, neig) && grid[neig.l][neig.c] == '#' {\n\t\t\t\tstack.Push(neig)\n\t\t\t}\n\t\t}\n\t}\n"},{"tag":"replace","a1":30,"a2":31,"text":"\tfor i := 0; i < nl; i++ {\n"}]}
