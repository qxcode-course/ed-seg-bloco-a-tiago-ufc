{"ts":1783739525,"hash":"1091a34cacd30dea127210df4bf55affd819a5474ac4e7a3d08ecd4623211937","mode":"diff","ops":[{"tag":"insert","a1":6,"a2":6,"text":"\t\"strconv\"\n"},{"tag":"insert","a1":8,"a2":8,"text":"\nfunc NewSet() *Set\n\nfunc findBinary(slice []int, value int) int {\n\tn := len(slice)\n\tif n == 0 {\n\t\treturn -1\n\t}\n\tleft, right := 0, n-1\n\tfound := -1\n\tfor left <= right {\n\t\tmid := (left + right) / 2\n\t\tif slice[mid] == value {\n\t\t\tfound = mid\n\t\t\tleft = mid + 1\n\t\t} else if slice[mid] < value {\n\t\t\tleft = mid + 1\n\t\t} else {\n\t\t\tright = mid - 1\n\t\t}\n\t}\n\treturn found\n}\n"},{"tag":"replace","a1":13,"a2":14,"text":"\tv := NewSet(0)\n"},{"tag":"replace","a1":28,"a2":30,"text":"\t\t\tvalue, _ := strconv.Atoi(parts[1])\n\t\t\tv = NewSet(value)\n"}]}
